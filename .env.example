# Brevo (SendInBlue) API Configuration
SEND_IN_BLUE_API_KEY=your_sendinblue_api_key_here
SEND_IN_BLUE_BASE_URL=https://api.brevo.com

# Contentful CMS Configuration
CONTENTFUL_SPACE_ID=your_contentful_space_id_here
CONTENTFUL_ACCESS_TOKEN=your_contentful_access_token_here

# NextAuth Configuration
NEXTAUTH_URL=https://checkified.se
NEXTAUTH_SECRET=your_nextauth_secret_here
JWT_SECRET=your_jwt_secret_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth Configuration (Optional)
# FACEBOOK_CLIENT_ID=your_facebook_client_id_here
# FACEBOOK_CLIENT_SECRET=your_facebook_client_secret_here

# API Configuration (Public URLs)
API_BASE=https://api.checkified.se/
FILE_BASE=https://api.checkified.se/public/uploads/

# Build Configuration (Optional)
# ANALYZE=true
